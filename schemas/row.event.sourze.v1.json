{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ROW Sourze Event",
  "type": "object",
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "sourze_id": { "type": "string" },
    "host_did": { "type": "string", "pattern": "^bostrom1[a-z0-9]+" },
    "ndm_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "decision": { "enum": ["ALLOWED", "QUARANTINED", "BLOCKED"] },
    "reason": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "row_shard_ref": { "type": "string" }
  },
  "required": ["event_id", "sourze_id", "host_did", "decision", "timestamp"]
}
